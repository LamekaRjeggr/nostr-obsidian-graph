    "builtin-modules": "3.2.0",
    "esbuild": "0.13.12",
    "obsidian": "0.12.0",
    "tslib": "2.3.1",
    "typescript": "4.4.4"
  },
  "dependencies": {
    "nostr-tools": "^1.17.0"
  }
